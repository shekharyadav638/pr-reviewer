# Bitbucket Configuration
BITBUCKET_USERNAME=shekhar.yadav@opensenselabs.com
BITBUCKET_APP_PASSWORD=
BITBUCKET_BASE_URL=https://api.bitbucket.org/2.0

# Workspace slugs to browse (comma-separated)
BITBUCKET_WORKSPACES=oslabsdevelopment

# Repositories to track (comma-separated as workspace/repo-slug)
BITBUCKET_REPOSITORIES=oslabsdevelopment/drupal-fit-portal

# Data collection settings
PR_FETCH_LIMIT=100
PR_STATE_FILTER=MERGED,DECLINED

# Model settings
MODEL_OUTPUT_DIR=models
DATA_OUTPUT_DIR=data/training

# Risk thresholds
RISK_HIGH_THRESHOLD=0.7
RISK_MEDIUM_THRESHOLD=0.4

# Label generation heuristics
LABEL_HIGH_COMMENT_THRESHOLD=5
LABEL_LONG_MERGE_HOURS=72
LABEL_MANY_COMMITS_THRESHOLD=10

# ── LLM Provider (PR review / chat) ──────────────────────────────────
# LLM_PROVIDER options: openai | openrouter | ollama | custom
LLM_PROVIDER=openai

# API key for the LLM provider
# For OpenAI:     your sk-... key
# For OpenRouter: your openrouter key (get one at openrouter.ai)
# For Ollama:     leave empty (no key needed)
LLM_API_KEY=your_api_key_here

# Model name
# OpenAI:      gpt-4.1 | gpt-4o | gpt-4o-mini
# OpenRouter:  openai/gpt-4o | anthropic/claude-3.5-sonnet | mistralai/mistral-7b-instruct
# Ollama:      llama3 | mistral | codellama
LLM_MODEL=gpt-4.1

# Override base URL (leave empty to use provider default)
# OpenRouter: https://openrouter.ai/api/v1  ← set automatically when LLM_PROVIDER=openrouter
# Ollama:     http://localhost:11434/v1      ← set automatically when LLM_PROVIDER=ollama
# Custom:     https://your-endpoint/v1
LLM_BASE_URL=

# ── Embedding Provider (repo indexing) ────────────────────────────────
# EMBEDDING_PROVIDER options: openai | openrouter | ollama | custom
EMBEDDING_PROVIDER=openai

# Separate key for embeddings (leave empty to reuse LLM_API_KEY)
EMBEDDING_API_KEY=

# Embedding model
# OpenAI:  text-embedding-3-small | text-embedding-3-large
# Ollama:  nomic-embed-text | mxbai-embed-large
EMBEDDING_MODEL=text-embedding-3-small

# Override base URL for embeddings (leave empty to use provider default)
EMBEDDING_BASE_URL=

# ── Legacy (still works, LLM_* vars take priority) ───────────────────
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4.1

# ── Server Ports ─────────────────────────────────────────────
# Port the FastAPI/uvicorn backend listens on
API_PORT=8000
# Port used by Vite dev server (npm run dev)
UI_PORT=5173

# ── Deployment ───────────────────────────────────────────────
# Your public domain name (used for nginx + webhook callback URL)
DOMAIN=your-domain.com
